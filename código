// Monitoreo de errores en el pronóstico
function logUserCorrection(originalTrend, correctedByUser) {
    if (originalTrend !== correctedByUser) {
        // Si el usuario corrige la tendencia, guardamos el dato para reentrenar el modelo
        Database.saveFeedback({
            expected: originalTrend,
